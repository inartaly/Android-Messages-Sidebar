{
  "manifest_version": 3,
  "name": "Android Messages Sidebar",
  "version": "1.4",
  "permissions": ["sidePanel", "declarativeNetRequest"],
  "host_permissions": ["*://messages.google.com/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
