{
  "manifest_version": 3,
  "name": "Android Messages Sidebar",
  "version": "1.7",
  "permissions": ["sidePanel"],
  "host_permissions": ["https://messages.google.com/*"],
  "action": {
    "default_title": "Open Google Messages",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
